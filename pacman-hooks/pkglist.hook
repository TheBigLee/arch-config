[Trigger]
Operation = Install
Operation = Remove
Operation = Upgrade
Type = Package
Target = *

[Action]
When = PostTransaction
Exec = /bin/sh -c 'pacman -Qqe > /home/bigli/dotfiles/pkglist.txt; pacman -Qqm > /home/bigli/dotfiles/aur-pkglist.txt'
Description = Updating package lists in dotfiles...
NeedsTargets
